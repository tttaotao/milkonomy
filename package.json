{
  "name": "@tttaotao/milkonomy",
  "type": "module",
  "version": "2.0.3",
  "description": "Community-maintained fork of milkonomy, built with Vue3, Vite, TypeScript, Element Plus, and more",
  "author": "luyh7 <470103427@qq.com> (https://github.com/luyh7)",
  "contributors": [
    "tttaotao (https://github.com/tttaotao)"
  ],
  "homepage": "https://github.com/tttaotao/milkonomy#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tttaotao/milkonomy.git"
  },
  "bugs": {
    "url": "https://github.com/tttaotao/milkonomy/issues"
  },
  "scripts": {
    "dev": "vite --mode private",
    "dev:public": "vite --mode public",
    "dev:private": "vite --mode private",
    "build:public": "vue-tsc && vite build --mode public",
    "build:private": "vue-tsc && vite build --mode private",
    "build:staging": "vue-tsc && vite build --mode staging",
    "build": "vue-tsc && vite build --mode public",
    "preview": "vite preview",
    "lint": "eslint . --fix",
    "prepare": "husky",
    "test": "vitest",
    "run-alchemy": "node --loader ts-node/esm --no-warnings scripts/alchemy-leaderboard/index.ts"
  },
  "dependencies": {
    "@element-plus/icons-vue": "2.3.1",
    "axios": "1.7.9",
    "dayjs": "1.11.13",
    "deep-freeze-strict": "1.1.1",
    "element-plus": "2.9.3",
    "js-cookie": "3.0.5",
    "lodash-es": "4.17.21",
    "mathjs": "14.2.1",
    "mitt": "3.0.1",
    "normalize.css": "8.0.1",
    "nprogress": "0.2.0",
    "path-browserify": "1.0.1",
    "path-to-regexp": "8.2.0",
    "pinia": "2.3.0",
    "screenfull": "6.0.2",
    "vue": "3.5.13",
    "vue-gtag-next": "1.14.0",
    "vue-i18n": "11.1.1",
    "vue-router": "4.5.0"
  },
  "devDependencies": {
    "@antfu/eslint-config": "3.14.0",
    "@types/deep-freeze-strict": "1.1.2",
    "@types/js-cookie": "3.0.6",
    "@types/lodash-es": "4.17.12",
    "@types/node": "22.13.1",
    "@types/nprogress": "0.2.3",
    "@types/path-browserify": "1.0.3",
    "@vitejs/plugin-vue": "5.2.1",
    "@vitejs/plugin-vue-jsx": "4.1.1",
    "@vue/test-utils": "2.4.6",
    "eslint": "9.18.0",
    "eslint-plugin-format": "1.0.1",
    "gh-pages": "6.3.0",
    "happy-dom": "16.6.0",
    "husky": "9.1.7",
    "lint-staged": "15.4.0",
    "sass": "1.78.0",
    "ts-node": "10.9.2",
    "typescript": "5.7.3",
    "unocss": "65.4.0",
    "unplugin-auto-import": "19.0.0",
    "unplugin-svg-component": "0.12.1",
    "unplugin-vue-components": "28.0.0",
    "vite": "6.0.7",
    "vite-svg-loader": "5.1.0",
    "vitest": "2.1.8",
    "vue-tsc": "2.2.0"
  },
  "lint-staged": {
    "*": "eslint --fix"
  }
}
